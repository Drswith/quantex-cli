{
  "name": "silver-cli",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "bun@1.3.9",
  "description": "统一的 AI Agent CLI 管理工具，支持安装、更新、卸载、查询、快捷启动主流 AI 编程助手",
  "author": "Drswith <drswith@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/Drswith/silver-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drswith/silver-cli.git"
  },
  "bugs": "https://github.com/Drswith/silver-cli/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "silver": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "bun run src/cli.ts",
    "lint": "eslint",
    "prepublishOnly": "bun run build",
    "release": "bumpp",
    "start": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "c12": "^3.0.4",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.6.1",
    "@types/bun": "^1.2.14",
    "@types/node": "^25.0.1",
    "@types/prompts": "^2.4.9",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun install --frozen-lockfile && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
