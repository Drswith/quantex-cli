{
  "name": "claude",
  "displayName": "Claude Code",
  "homepage": "https://code.claude.com/docs",
  "binaryName": "claude",
  "selfUpdate": {
    "command": ["claude", "update"],
    "fallbackCommands": [["claude", "upgrade"]]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@anthropic-ai/claude-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@anthropic-ai/claude-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://claude.ai/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://claude.ai/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "winget",
        "target": {
          "id": "Anthropic.ClaudeCode",
          "kind": "id"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@anthropic-ai/claude-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@anthropic-ai/claude-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://claude.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://claude.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "claude-code",
          "kind": "cask"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@anthropic-ai/claude-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@anthropic-ai/claude-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://claude.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://claude.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "claude-code",
          "kind": "cask"
        }
      }
    ]
  }
}
