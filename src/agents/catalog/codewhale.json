{
  "name": "codewhale",
  "displayName": "CodeWhale",
  "homepage": "https://github.com/Hmbown/CodeWhale",
  "binaryName": "codewhale",
  "selfUpdate": {
    "command": ["codewhale", "update"]
  },
  "versionProbe": {
    "command": ["codewhale", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "codewhale",
          "kind": "package"
        }
      },
      {
        "provider": "cargo",
        "target": {
          "id": "codewhale-cli",
          "kind": "package",
          "arguments": ["--locked"]
        },
        "probes": ["executable-presence"]
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "codewhale",
          "kind": "package"
        }
      },
      {
        "provider": "cargo",
        "target": {
          "id": "codewhale-cli",
          "kind": "package",
          "arguments": ["--locked"]
        },
        "probes": ["executable-presence"]
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "codewhale",
          "kind": "package"
        }
      },
      {
        "provider": "cargo",
        "target": {
          "id": "codewhale-cli",
          "kind": "package",
          "arguments": ["--locked"]
        },
        "probes": ["executable-presence"]
      }
    ]
  }
}
