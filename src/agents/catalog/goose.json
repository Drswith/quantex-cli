{
  "name": "goose",
  "displayName": "Goose",
  "homepage": "https://github.com/aaif-goose/goose",
  "binaryName": "goose",
  "selfUpdate": {
    "command": ["goose", "update"]
  },
  "versionProbe": {
    "command": ["goose", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://raw.githubusercontent.com/aaif-goose/goose/main/download_cli.ps1",
          "kind": "script",
          "effect": {
            "command": "Invoke-WebRequest -Uri \"https://raw.githubusercontent.com/aaif-goose/goose/main/download_cli.ps1\" -OutFile \"download_cli.ps1\"; ./download_cli.ps1",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "block-goose-cli",
          "kind": "formula"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://github.com/aaif-goose/goose/releases/download/stable/download_cli.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "block-goose-cli",
          "kind": "formula"
        }
      }
    ]
  }
}
