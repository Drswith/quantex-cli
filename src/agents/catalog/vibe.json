{
  "name": "vibe",
  "lookupAliases": ["mistral-vibe"],
  "displayName": "Mistral Vibe",
  "homepage": "https://docs.mistral.ai/mistral-vibe/terminal/install",
  "binaryName": "vibe",
  "versionProbe": {
    "command": ["vibe", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "provider": "uv",
        "target": {
          "id": "mistral-vibe",
          "kind": "tool"
        },
        "probes": ["executable-presence", "installed-version", "package-presence"],
        "legacy": {
          "packageNameInMethod": true
        }
      },
      {
        "provider": "pip",
        "target": {
          "id": "mistral-vibe",
          "kind": "package"
        },
        "probes": ["executable-presence"],
        "legacy": {
          "packageNameInMethod": true
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://mistral.ai/vibe/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -LsSf https://mistral.ai/vibe/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
