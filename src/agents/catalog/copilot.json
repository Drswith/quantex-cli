{
  "name": "copilot",
  "displayName": "GitHub Copilot CLI",
  "homepage": "https://github.com/features/copilot/cli",
  "binaryName": "copilot",
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "winget",
        "target": {
          "id": "GitHub.Copilot",
          "kind": "id"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@github/copilot",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@github/copilot",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://gh.io/copilot-install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://gh.io/copilot-install | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "copilot-cli",
          "kind": "formula"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@github/copilot",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@github/copilot",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://gh.io/copilot-install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://gh.io/copilot-install | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "copilot-cli",
          "kind": "formula"
        }
      }
    ]
  }
}
