{
  "name": "hermes",
  "lookupAliases": ["hermes-agent"],
  "displayName": "Hermes Agent",
  "homepage": "https://github.com/NousResearch/hermes-agent",
  "binaryName": "hermes",
  "selfUpdate": {
    "command": ["hermes", "update"]
  },
  "versionProbe": {
    "command": ["hermes", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://hermes-agent.nousresearch.com/install.ps1",
          "kind": "script",
          "effect": {
            "command": "iex (irm https://hermes-agent.nousresearch.com/install.ps1)",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://hermes-agent.nousresearch.com/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://hermes-agent.nousresearch.com/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
