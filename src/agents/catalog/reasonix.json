{
  "name": "reasonix",
  "lookupAliases": ["deepseek-reasonix"],
  "displayName": "Reasonix",
  "homepage": "https://github.com/esengine/DeepSeek-Reasonix",
  "binaryName": "reasonix",
  "selfUpdate": {
    "command": ["reasonix", "update"]
  },
  "versionProbe": {
    "command": ["reasonix", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "reasonix",
          "kind": "package"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "reasonix",
          "kind": "package"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "reasonix",
          "kind": "package"
        }
      }
    ]
  }
}
