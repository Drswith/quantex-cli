{
  "name": "autohand",
  "lookupAliases": ["autohand-cli"],
  "displayName": "Autohand Code CLI",
  "homepage": "https://autohand.ai/cli/",
  "packages": {
    "npm": "autohand-cli"
  },
  "binaryName": "autohand",
  "versionProbe": {
    "command": ["autohand", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://autohand.ai/install.ps1",
          "kind": "script",
          "effect": {
            "command": "iwr -useb https://autohand.ai/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://autohand.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://autohand.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://autohand.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://autohand.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
