{
  "name": "kiro",
  "lookupAliases": ["kiro-cli"],
  "displayName": "Kiro CLI",
  "homepage": "https://kiro.dev/cli/",
  "binaryName": "kiro-cli",
  "versionProbe": {
    "command": ["kiro-cli", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cli.kiro.dev/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm 'https://cli.kiro.dev/install.ps1' | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cli.kiro.dev/install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://cli.kiro.dev/install | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cli.kiro.dev/install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://cli.kiro.dev/install | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
