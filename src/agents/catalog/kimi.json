{
  "name": "kimi",
  "lookupAliases": ["kimi-code", "kimi-cli"],
  "displayName": "Kimi Code",
  "homepage": "https://moonshotai.github.io/kimi-code/",
  "binaryName": "kimi",
  "selfUpdate": {
    "command": ["kimi", "upgrade"]
  },
  "versionProbe": {
    "command": ["kimi", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://code.kimi.com/kimi-code/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://code.kimi.com/kimi-code/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@moonshot-ai/kimi-code",
          "kind": "package"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://code.kimi.com/kimi-code/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://code.kimi.com/kimi-code/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@moonshot-ai/kimi-code",
          "kind": "package"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://code.kimi.com/kimi-code/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://code.kimi.com/kimi-code/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@moonshot-ai/kimi-code",
          "kind": "package"
        }
      }
    ]
  }
}
