{
  "name": "deepcode",
  "displayName": "Deep Code CLI",
  "homepage": "https://github.com/lessweb/deepcode-cli",
  "binaryName": "deepcode",
  "versionProbe": {
    "command": ["deepcode", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@vegamo/deepcode-cli",
          "kind": "package"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@vegamo/deepcode-cli",
          "kind": "package"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@vegamo/deepcode-cli",
          "kind": "package"
        }
      }
    ]
  }
}
