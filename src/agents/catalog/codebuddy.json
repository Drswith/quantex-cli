{
  "name": "codebuddy",
  "lookupAliases": ["codebuddy-code"],
  "displayName": "CodeBuddy Code",
  "homepage": "https://www.codebuddy.cn/docs/cli/installation",
  "binaryName": "codebuddy",
  "selfUpdate": {
    "command": ["codebuddy", "update"]
  },
  "versionProbe": {
    "command": ["codebuddy", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@tencent-ai/codebuddy-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@tencent-ai/codebuddy-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://www.codebuddy.cn/cli/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://www.codebuddy.cn/cli/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@tencent-ai/codebuddy-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@tencent-ai/codebuddy-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://www.codebuddy.cn/cli/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://www.codebuddy.cn/cli/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "Tencent-CodeBuddy/tap/codebuddy-code",
          "kind": "formula"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@tencent-ai/codebuddy-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@tencent-ai/codebuddy-code",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://www.codebuddy.cn/cli/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://www.codebuddy.cn/cli/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "Tencent-CodeBuddy/tap/codebuddy-code",
          "kind": "formula"
        }
      }
    ]
  }
}
