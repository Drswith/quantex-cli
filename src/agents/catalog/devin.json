{
  "name": "devin",
  "displayName": "Devin for Terminal",
  "homepage": "https://cli.devin.ai/",
  "binaryName": "devin",
  "selfUpdate": {
    "command": ["devin", "update"]
  },
  "versionProbe": {
    "command": ["devin", "version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://static.devin.ai/cli/setup.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://static.devin.ai/cli/setup.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cli.devin.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://cli.devin.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cli.devin.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://cli.devin.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
