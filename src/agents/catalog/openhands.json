{
  "name": "openhands",
  "displayName": "OpenHands CLI",
  "homepage": "https://docs.openhands.dev/openhands/usage/cli/installation",
  "binaryName": "openhands",
  "selfUpdate": {
    "command": ["uv", "tool", "upgrade", "openhands", "--python", "3.12"]
  },
  "versionProbe": {
    "command": ["openhands", "--version"]
  },
  "platforms": {
    "macos": [
      {
        "provider": "uv",
        "target": {
          "id": "openhands",
          "kind": "tool",
          "arguments": ["--python", "3.12"]
        },
        "probes": ["executable-presence", "installed-version", "package-presence"]
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://install.openhands.dev/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://install.openhands.dev/install.sh | sh",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "provider": "uv",
        "target": {
          "id": "openhands",
          "kind": "tool",
          "arguments": ["--python", "3.12"]
        },
        "probes": ["executable-presence", "installed-version", "package-presence"]
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://install.openhands.dev/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://install.openhands.dev/install.sh | sh",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
