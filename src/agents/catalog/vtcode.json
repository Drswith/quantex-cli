{
  "name": "vtcode",
  "displayName": "VTCode",
  "homepage": "https://github.com/vinhnx/vtcode",
  "binaryName": "vtcode",
  "selfUpdate": {
    "command": ["vtcode", "update"]
  },
  "versionProbe": {
    "command": ["vtcode", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "provider": "cargo",
        "target": {
          "id": "vtcode",
          "kind": "package"
        },
        "probes": ["executable-presence"]
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://raw.githubusercontent.com/vinhnx/vtcode/main/scripts/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://raw.githubusercontent.com/vinhnx/vtcode/main/scripts/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://raw.githubusercontent.com/vinhnx/vtcode/main/scripts/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://raw.githubusercontent.com/vinhnx/vtcode/main/scripts/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "provider": "cargo",
        "target": {
          "id": "vtcode",
          "kind": "package"
        },
        "probes": ["executable-presence"]
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "vtcode",
          "kind": "formula"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://raw.githubusercontent.com/vinhnx/vtcode/main/scripts/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://raw.githubusercontent.com/vinhnx/vtcode/main/scripts/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "provider": "cargo",
        "target": {
          "id": "vtcode",
          "kind": "package"
        },
        "probes": ["executable-presence"]
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "vtcode",
          "kind": "formula"
        }
      }
    ]
  }
}
