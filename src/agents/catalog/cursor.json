{
  "name": "cursor",
  "lookupAliases": ["agent"],
  "displayName": "Cursor CLI",
  "homepage": "https://cursor.com/docs/cli",
  "binaryName": "agent",
  "selfUpdate": {
    "command": ["agent", "update"]
  },
  "versionProbe": {
    "command": ["agent", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cursor.com/install?win32=true",
          "kind": "script",
          "effect": {
            "command": "irm 'https://cursor.com/install?win32=true' | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cursor.com/install",
          "kind": "script",
          "effect": {
            "command": "curl https://cursor.com/install -fsS | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://cursor.com/install",
          "kind": "script",
          "effect": {
            "command": "curl https://cursor.com/install -fsS | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
