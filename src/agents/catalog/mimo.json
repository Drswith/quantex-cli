{
  "name": "mimo",
  "lookupAliases": ["mimocode", "mimo-code"],
  "displayName": "MiMoCode",
  "homepage": "https://github.com/XiaomiMiMo/MiMo-Code",
  "binaryName": "mimo",
  "versionProbe": {
    "command": ["mimo", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@mimo-ai/cli",
          "kind": "package"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://mimo.xiaomi.com/install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://mimo.xiaomi.com/install | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@mimo-ai/cli",
          "kind": "package"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://mimo.xiaomi.com/install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://mimo.xiaomi.com/install | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@mimo-ai/cli",
          "kind": "package"
        }
      }
    ]
  }
}
