{
  "name": "grok",
  "lookupAliases": ["grok-build"],
  "displayName": "Grok Build",
  "homepage": "https://docs.x.ai/build/overview",
  "binaryName": "grok",
  "selfUpdate": {
    "command": ["grok", "update"]
  },
  "versionProbe": {
    "command": ["grok", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://x.ai/cli/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://x.ai/cli/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://x.ai/cli/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://x.ai/cli/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://x.ai/cli/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://x.ai/cli/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
