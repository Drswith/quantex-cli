{
  "name": "junie",
  "displayName": "Junie CLI",
  "homepage": "https://junie.jetbrains.com/docs/junie-cli.html",
  "binaryName": "junie",
  "versionProbe": {
    "command": ["junie", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@jetbrains/junie",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@jetbrains/junie",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://junie.jetbrains.com/install.ps1",
          "kind": "script",
          "effect": {
            "command": "iex (irm 'https://junie.jetbrains.com/install.ps1')",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@jetbrains/junie",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@jetbrains/junie",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://junie.jetbrains.com/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://junie.jetbrains.com/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "jetbrains-junie/junie/junie",
          "kind": "formula"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@jetbrains/junie",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@jetbrains/junie",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://junie.jetbrains.com/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://junie.jetbrains.com/install.sh | bash",
            "kind": "shell-script"
          }
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "jetbrains-junie/junie/junie",
          "kind": "formula"
        }
      }
    ]
  }
}
