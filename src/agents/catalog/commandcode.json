{
  "name": "commandcode",
  "lookupAliases": ["command-code", "cmd", "cmdc"],
  "displayName": "Command Code",
  "homepage": "https://commandcode.ai/docs/quickstart",
  "binaryName": "command-code",
  "selfUpdate": {
    "command": ["command-code", "update"]
  },
  "versionProbe": {
    "command": ["command-code", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "command-code",
          "kind": "package"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "command-code",
          "kind": "package"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "command-code",
          "kind": "package"
        }
      }
    ]
  }
}
