{
  "name": "antigravity",
  "lookupAliases": ["agy", "antigravity-cli"],
  "displayName": "Antigravity CLI",
  "homepage": "https://antigravity.google/product/antigravity-cli",
  "binaryName": "agy",
  "selfUpdate": {
    "command": ["agy", "update"]
  },
  "versionProbe": {
    "command": ["agy", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://antigravity.google/cli/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://antigravity.google/cli/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://antigravity.google/cli/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://antigravity.google/cli/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://antigravity.google/cli/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://antigravity.google/cli/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
