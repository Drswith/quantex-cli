{
  "name": "openclaw",
  "displayName": "OpenClaw",
  "homepage": "https://github.com/openclaw/openclaw",
  "binaryName": "openclaw",
  "selfUpdate": {
    "command": ["openclaw", "update"]
  },
  "versionProbe": {
    "command": ["openclaw", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "openclaw",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "openclaw",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://openclaw.ai/install.ps1",
          "kind": "script",
          "effect": {
            "command": "iwr -useb https://openclaw.ai/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "openclaw",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "openclaw",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://openclaw.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://openclaw.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "openclaw",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "openclaw",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://openclaw.ai/install.sh",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://openclaw.ai/install.sh | bash",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
