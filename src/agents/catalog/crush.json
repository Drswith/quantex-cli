{
  "name": "crush",
  "displayName": "Crush",
  "homepage": "https://github.com/charmbracelet/crush",
  "binaryName": "crush",
  "selfUpdate": {
    "command": ["crush", "update"]
  },
  "versionProbe": {
    "command": ["crush", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@charmland/crush",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@charmland/crush",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "winget",
        "target": {
          "id": "charmbracelet.crush",
          "kind": "id"
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@charmland/crush",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@charmland/crush",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "charmbracelet/tap/crush",
          "kind": "formula"
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@charmland/crush",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "npm",
        "target": {
          "id": "@charmland/crush",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "brew",
        "target": {
          "id": "charmbracelet/tap/crush",
          "kind": "formula"
        }
      }
    ]
  }
}
