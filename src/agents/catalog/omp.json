{
  "name": "omp",
  "displayName": "oh-my-pi (OMP)",
  "homepage": "https://github.com/can1357/oh-my-pi",
  "binaryName": "omp",
  "versionProbe": {
    "command": ["omp", "--version"]
  },
  "platforms": {
    "windows": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@oh-my-pi/pi-coding-agent",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://omp.sh/install.ps1",
          "kind": "script",
          "effect": {
            "command": "irm https://omp.sh/install.ps1 | iex",
            "kind": "shell-script"
          }
        }
      }
    ],
    "macos": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@oh-my-pi/pi-coding-agent",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://omp.sh/install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://omp.sh/install | sh",
            "kind": "shell-script"
          }
        }
      }
    ],
    "linux": [
      {
        "probes": ["executable-presence", "installed-version", "package-presence", "target-version"],
        "provider": "bun",
        "target": {
          "id": "@oh-my-pi/pi-coding-agent",
          "kind": "package"
        }
      },
      {
        "probes": ["executable-presence"],
        "provider": "script",
        "target": {
          "id": "https://omp.sh/install",
          "kind": "script",
          "effect": {
            "command": "curl -fsSL https://omp.sh/install | sh",
            "kind": "shell-script"
          }
        }
      }
    ]
  }
}
