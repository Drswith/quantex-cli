                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "packageName": {
                      "type": "string",
                      "minLength": 1
                    },
                    "packageTargetKind": {
                      "type": "string",
                      "enum": ["package", "cask", "id"]
                    },
                    "type": {
                      "type": "string",
                      "enum": ["bun", "npm", "brew", "cargo", "deno", "mise", "pip", "uv", "winget"]
                    }
