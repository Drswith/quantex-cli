          "pip": {
            "type": "string",
            "minLength": 1
          },
          "uv": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "platforms": {
        "type": "object",
        "properties": {
          "linux": {
            "minItems": 1,
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "binaryName": {
                      "type": "string",
                      "minLength": 1
                    },
                    "packageInstallArgs": {
                      "minItems": 1,
                      "type": "array",
