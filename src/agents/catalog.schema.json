      "binaryName": {
        "type": "string",
        "minLength": 1
      },
      "displayName": {
        "type": "string",
        "minLength": 1
      },
      "homepage": {
        "type": "string",
        "format": "uri",
        "pattern": "^https:\\/\\/.*"
      },
      "lookupAliases": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "packages": {
        "type": "object",
        "properties": {
          "cargo": {
            "type": "string",
            "minLength": 1
