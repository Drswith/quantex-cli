            }
          },
          "versionAfter": {
            "type": "string",
            "enum": ["same-process", "respawn"]
          }
        },
        "required": ["command"],
        "additionalProperties": false
      },
      "versionProbe": {
        "type": "object",
        "properties": {
          "command": {
            "minItems": 1,
            "type": "array",
            "items": {
